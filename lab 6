2007&lt;/th&gt;&lt;th&gt;Symbol&lt;/th&gt;&lt;/tr&gt;&quot;;
 
for(item of stock) { table +=
&quot;&lt;tr&gt;&lt;td&gt;&quot;+item.company+&quot;&lt;/td&gt;&lt;td&gt;&quot;+item.description+&quot;&lt;/td&gt;&lt;td&gt;&quot;+item.init
ial_price+&quot;&lt;/td&gt;&lt;td&gt;&quot;+item.price_2007+&quot;&lt;/td&gt;&lt;td&gt;&quot;+item.symbol+&quot;&lt;/td&gt;&lt;/tr&gt;&quot;
;
}
 
table += &quot;&lt;/table&gt;&quot;;
 
// inserting the table into html document.getElementById(&quot;stock&quot;).innerHTML = table;
})
